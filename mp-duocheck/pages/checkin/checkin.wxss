.container {
  padding: 30rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 30rpx;
  display: block;
}

.goal-checkin-card {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
  margin-bottom: 30rpx;
}

.goal-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
}

.goal-desc {
  font-size: 24rpx;
  color: #94a3b8;
}

.text-area-input {
  height: 120rpx;
  margin-bottom: 20rpx;
}

/* Image Uploader Grid */
.uploader-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
  margin-bottom: 20rpx;
}

.uploader-preview {
  position: relative;
  width: 140rpx;
  height: 140rpx;
}

.preview-img {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
}

.delete-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 32rpx;
  height: 32rpx;
  background: rgba(239, 68, 68, 0.9);
  color: #ffffff;
  border-radius: 50%;
  text-align: center;
  line-height: 28rpx;
  font-size: 24rpx;
}

.uploader-action {
  width: 140rpx;
  height: 140rpx;
  border: 1rpx dashed rgba(255, 255, 255, 0.2);
  background: rgba(255, 255, 255, 0.03);
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.uploader-icon {
  font-size: 40rpx;
  color: #94a3b8;
}

.uploader-text {
  font-size: 18rpx;
  color: #94a3b8;
  margin-top: 5rpx;
}

.photo-grid {
  display: flex;
  gap: 15rpx;
  margin-top: 15rpx;
}

.photo-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
}

.verify-action-box {
  margin-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.05);
  padding-top: 20rpx;
}

.verify-input {
  margin-bottom: 15rpx;
}

.verify-btns {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
}

.verify-btn {
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  margin: 0;
  line-height: 1.4;
}

.verify-status {
  margin-top: 15rpx;
  background: rgba(255, 255, 255, 0.03);
  padding: 15rpx;
  border-radius: 8rpx;
}

.verify-comment {
  font-size: 24rpx;
  color: #cbd5e1;
  display: block;
  margin-top: 10rpx;
}
.empty-state {
  text-align: center;
  padding: 80rpx 0;
}
.empty-text {
  font-size: 26rpx;
  color: #94a3b8;
}
.submit-checkin-btn {
  width: 100%;
}
