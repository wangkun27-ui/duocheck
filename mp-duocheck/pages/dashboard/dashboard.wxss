.container {
  padding: 30rpx;
}

.welcome-section {
  padding: 40rpx 30rpx;
}

.welcome-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.welcome-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
}

.streak-badge {
  margin-top: 15rpx;
}

.streak-fire {
  font-size: 28rpx;
  color: #f59e0b;
  font-weight: 600;
}

.logout-btn {
  font-size: 24rpx;
  background: rgba(239, 68, 68, 0.15);
  color: #ef4444;
  border: 1rpx solid rgba(239, 68, 68, 0.3);
  padding: 10rpx 24rpx;
  margin: 0;
  border-radius: 8rpx;
}

.actions-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.action-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 30rpx 10rpx;
  margin-bottom: 0;
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.action-name {
  font-size: 24rpx;
  color: #cbd5e1;
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 24rpx;
  display: block;
}

.goal-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.goal-info {
  flex: 1;
  padding-right: 20rpx;
}

.goal-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
  display: block;
}

.goal-desc {
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 8rpx;
  display: block;
}

.checkin-btn {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  margin: 0;
  background: rgba(139, 92, 246, 0.2);
  color: #8b5cf6;
  border: 1rpx solid rgba(139, 92, 246, 0.3);
}

.dissolve-alert {
  display: flex;
  align-items: flex-start;
  background: rgba(239, 68, 68, 0.1);
  border: 1rpx solid rgba(239, 68, 68, 0.2);
  margin-top: 30rpx;
}

.alert-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.alert-content {
  flex: 1;
}

.alert-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #fca5a5;
  display: block;
}

.alert-desc {
  font-size: 24rpx;
  color: #fca5a5;
  margin-top: 6rpx;
  display: block;
  line-height: 1.4;
}

.empty-state {
  text-align: center;
  padding: 60rpx 0;
}

.empty-text {
  font-size: 26rpx;
  color: #94a3b8;
  display: block;
}
.mt-2 {
  margin-top: 20rpx;
}
