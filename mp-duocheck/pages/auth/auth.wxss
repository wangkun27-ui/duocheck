.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
  min-height: 80vh;
}

.logo-area {
  text-align: center;
  margin-bottom: 60rpx;
}

.logo-title {
  font-size: 64rpx;
  font-weight: 700;
  color: #ffffff;
  display: block;
  text-shadow: 0 4rpx 20rpx rgba(139, 92, 246, 0.4);
}

.logo-subtitle {
  font-size: 26rpx;
  color: #94a3b8;
  margin-top: 10rpx;
  display: block;
  letter-spacing: 2rpx;
}

.form-card {
  width: 100%;
  box-sizing: border-box;
}

.tab-header {
  display: flex;
  justify-content: space-around;
  margin-bottom: 50rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
  padding-bottom: 20rpx;
}

.tab-title {
  font-size: 32rpx;
  color: #94a3b8;
  padding: 10rpx 20rpx;
  position: relative;
}

.tab-title.active {
  color: #ffffff;
  font-weight: 600;
}

.tab-title.active::after {
  content: '';
  position: absolute;
  bottom: -22rpx;
  left: 0;
  width: 100%;
  height: 4rpx;
  background: #10b981;
  border-radius: 2rpx;
}

.submit-btn {
  margin-top: 40rpx;
  width: 100%;
}
