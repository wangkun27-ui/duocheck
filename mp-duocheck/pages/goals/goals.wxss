.container {
  padding: 30rpx;
}

.header-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
}

.add-btn {
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  margin: 0;
}

.badge-row {
  margin-top: 15rpx;
}

.goal-card {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.goal-actions {
  display: flex;
  justify-content: flex-end;
  gap: 15rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.05);
  padding-top: 15rpx;
}

.action-btn {
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  margin: 0;
  border-radius: 8rpx;
}

.btn-ghost {
  background: rgba(255, 255, 255, 0.08);
  color: #f1f5f9;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
}

.btn-danger-ghost {
  background: rgba(239, 68, 68, 0.15);
  color: #ef4444;
  border: 1rpx solid rgba(239, 68, 68, 0.3);
}

/* Modal Overlay */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.modal-overlay.active {
  opacity: 1;
  pointer-events: auto;
}

.modal-content {
  width: 80%;
  margin-bottom: 0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 30rpx;
  display: block;
}

.text-area-input {
  height: 150rpx;
}

.modal-actions {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  margin-top: 30rpx;
}

.modal-btn {
  font-size: 24rpx;
  padding: 12rpx 30rpx;
  margin: 0;
  border-radius: 8rpx;
}

.btn-cancel {
  background: transparent;
  color: #94a3b8;
  border: 1rpx solid rgba(255,255,255,0.1);
}

.btn-confirm {
  background: #10b981;
  color: #ffffff;
}
.empty-state {
  text-align: center;
  padding: 80rpx 0;
}
.empty-text {
  font-size: 26rpx;
  color: #94a3b8;
}
