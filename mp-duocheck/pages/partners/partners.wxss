.container {
  padding: 30rpx;
}

.section {
  margin-bottom: 40rpx;
}

.search-box {
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.search-input {
  flex: 1;
  margin-bottom: 0;
}

.search-btn {
  font-size: 24rpx;
  padding: 18rpx 30rpx;
  margin: 0;
  height: 80rpx;
  line-height: 44rpx;
}

.search-results {
  margin-top: 20rpx;
}

.search-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
  padding: 20rpx 30rpx;
}

.user-name {
  font-size: 28rpx;
  color: #ffffff;
}

.invite-btn {
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  margin: 0;
}

.request-card {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.request-user {
  font-size: 26rpx;
  color: #ffffff;
}

.request-actions {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
}

.request-btn {
  font-size: 22rpx;
  padding: 8rpx 24rpx;
  margin: 0;
  line-height: 1.4;
}

.partner-card {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.partner-header {
  display: flex;
  justify-content: space-between;
}

.partner-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
}

.streak-count {
  font-size: 26rpx;
  color: #f59e0b;
  font-weight: 600;
}

.partner-footer {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.05);
  padding-top: 15rpx;
}

.partner-btn {
  font-size: 22rpx;
  padding: 8rpx 24rpx;
  margin: 0;
  line-height: 1.4;
}
.empty-state {
  text-align: center;
  padding: 60rpx 0;
}
.empty-text {
  font-size: 26rpx;
  color: #94a3b8;
}
