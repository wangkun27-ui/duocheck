/* 全局样式定义 - 延续 Web 端的深色玻璃微光（Glassmorphism）系统 */
page {
  background: linear-gradient(180deg, #0a0a1a 0%, #1a1035 50%, #0d1b2a 100%);
  color: #f1f5f9;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 玻璃质感卡片 */
.glass-card {
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 32rpx 0 rgba(0, 0, 0, 0.2);
}

/* 渐变绿色主按钮 */
.btn-primary {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  padding: 24rpx 0;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.3);
}

.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.98);
}

/* 渐变紫色次按钮 */
.btn-secondary {
  background: linear-gradient(135deg, #8b5cf6 0%, #6366f1 100%);
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  padding: 24rpx 0;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(139, 92, 246, 0.3);
}

/* 危险按钮（如删除） */
.btn-danger {
  background: #ef4444;
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  padding: 24rpx 0;
  border: none;
}

/* 输入框 */
.form-input {
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  color: #f1f5f9;
  font-size: 28rpx;
  margin-bottom: 24rpx;
}

.form-input-placeholder {
  color: #94a3b8;
}

/* 标签徽章 */
.badge {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.badge-success {
  background: rgba(16, 185, 129, 0.2);
  color: #34d399;
  border: 1rpx solid rgba(16, 185, 129, 0.3);
}

.badge-danger {
  background: rgba(239, 68, 68, 0.2);
  color: #fca5a5;
  border: 1rpx solid rgba(239, 68, 68, 0.3);
}

.badge-secondary {
  background: rgba(148, 163, 184, 0.2);
  color: #cbd5e1;
  border: 1rpx solid rgba(148, 163, 184, 0.3);
}

.badge-warning {
  background: rgba(245, 158, 11, 0.2);
  color: #fcd34d;
  border: 1rpx solid rgba(245, 158, 11, 0.3);
}
